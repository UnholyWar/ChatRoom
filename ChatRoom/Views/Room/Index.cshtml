@{
    ViewData["Title"] = ViewBag.RoomName + " · ChatRoom";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="room-data"
     data-room-id="@ViewBag.RoomId"
     data-room-name="@ViewBag.RoomName"
     data-nickname="@ViewBag.Nickname"
     data-color="@ViewBag.Color">
</div>

<div class="room-layout">

    <!-- Header -->
    <header class="room-header">
        <div class="rh-left">
            <a href="/Lobby" class="btn-ghost btn-sm btn-icon-text">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                Geri
            </a>
            <div class="rh-room-info">
                <span class="rh-dot"></span>
                <span class="rh-name"># @ViewBag.RoomName</span>
            </div>
        </div>
        <div class="rh-right">
            <div class="rh-status">
                <span class="status-dot"></span>
                <span id="user-count">0</span> kullanıcı
            </div>
            <a href="/Home/Logout" class="btn-ghost btn-sm">Çıkış</a>
        </div>
    </header>

    <!-- Body -->
    <div class="room-body">

        <!-- Chat -->
        <section class="chat-panel">
            <div class="messages" id="messages">
                <div class="messages-welcome">
                    <div class="welcome-icon">#</div>
                    <h3>@ViewBag.RoomName odası</h3>
                    <p>Sohbet burada başlıyor.</p>
                </div>
            </div>
            <div class="chat-input-bar">
                <input type="text"
                       id="message-input"
                       placeholder="@ViewBag.RoomName kanalına mesaj yaz..."
                       maxlength="500"
                       autocomplete="off"
                       spellcheck="false" />
                <button id="btn-send" title="Gönder">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
                </button>
            </div>
        </section>

        <!-- Sidebar -->
        <aside class="side-panel">

            <!-- Users -->
            <div class="sp-section sp-users">
                <div class="sp-section-head">
                    <span>Kullanıcılar</span>
                    <span class="sp-badge" id="user-count-badge">0</span>
                </div>
                <div id="users-list" class="users-list"></div>
            </div>

            <!-- Audio Controls -->
            <div class="sp-section sp-audio">
                <div class="sp-section-head">
                    <span>Ses Ayarları</span>
                </div>
                <div class="audio-controls">

                    <div class="ac-row">
                        <label class="ac-label">Mikrofon</label>
                        <select id="mic-device" class="ac-select"></select>
                    </div>

                    <button id="btn-mute" class="ac-mute-btn">
                        <svg class="icon-mic" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/></svg>
                        <svg class="icon-mic-off" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><line x1="1" y1="1" x2="23" y2="23"/><path d="M9 9v3a3 3 0 0 0 5.12 2.12M15 9.34V4a3 3 0 0 0-5.94-.6"/><path d="M17 16.95A7 7 0 0 1 5 12v-2m14 0v2a7 7 0 0 1-.11 1.23M12 19v4M8 23h8"/></svg>
                        <span class="mute-label">Mikrofon Açık</span>
                    </button>

                    <div class="ac-slider-row">
                        <div class="ac-slider-head">
                            <span class="ac-slider-label">Ses Seviyesi</span>
                            <span class="ac-slider-val" id="gain-value">100%</span>
                        </div>
                        <input type="range" class="ac-slider" id="gain-slider" min="0" max="2" step="0.05" value="1" />
                    </div>

                    <div class="ac-slider-row">
                        <div class="ac-slider-head">
                            <span class="ac-slider-label">Gürültü Engeli</span>
                            <span class="ac-slider-val" id="gate-value">Kapalı</span>
                        </div>
                        <input type="range" class="ac-slider ac-slider-gate" id="gate-slider" min="0" max="100" step="1" value="0" />
                        <p class="ac-hint">Konuşmadığınızda arka plan sesini keser</p>
                    </div>

                </div>
            </div>

        </aside>
    </div>
</div>

@section Scripts {
    <script src="~/js/audio.js" asp-append-version="true"></script>
    <script src="~/js/webrtc.js" asp-append-version="true"></script>
    <script src="~/js/room.js" asp-append-version="true"></script>
}
