@{
    ViewData["Title"] = "ChatRoom — Lobisi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var nickname = (string)ViewBag.Nickname;
    var color    = (string)ViewBag.Color;
}

<div id="lobby-data" data-nickname="@nickname" data-color="@color"></div>

<div class="app-layout">

    <header class="app-header">
        <div class="app-header-brand">
            <div class="brand-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20 2H4C2.9 2 2 2.9 2 4V22L6 18H20C21.1 18 22 17.1 22 16V4C22 2.9 21.1 2 20 2Z"/>
                </svg>
            </div>
            <span class="brand-name">ChatRoom</span>
        </div>

        <div class="app-header-user">
            <div class="user-avatar" style="background:@color">
                @nickname.Substring(0, 1).ToUpper()
            </div>
            <span class="user-label" style="color:@color">@nickname</span>
            <a href="/Home/Logout" class="btn-ghost btn-sm">Çıkış</a>
        </div>
    </header>

    <main class="lobby-main">
        <div class="lobby-heading">
            <h2>Odalar</h2>
            <p>Bir odayı seçerek sesli ve yazılı sohbete katılın</p>
        </div>

        <div class="rooms-grid">
            @foreach (var room in (IEnumerable<ChatRoom.Models.RoomDefinition>)ViewBag.Rooms)
            {
                <a href="/room/@room.Id" class="room-card">
                    <div class="rc-header">
                        <div class="rc-icon">#</div>
                        <div class="rc-live" id="live-@room.Id"></div>
                    </div>
                    <div class="rc-name">@room.Name</div>
                    <div class="rc-footer">
                        <div class="rc-count" id="count-@room.Id">
                            <span class="rc-dot"></span>
                            <span class="rc-num">0</span> kullanıcı
                        </div>
                        <div class="rc-arrow">→</div>
                    </div>
                </a>
            }
        </div>
    </main>
</div>

@section Scripts {
    <script src="~/js/lobby.js" asp-append-version="true"></script>
}
